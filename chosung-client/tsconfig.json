{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",

    "baseUrl": "src",
    "paths": {
      "@api/*": ["api/*"],
      "@/*": ["*"]
    }
  },
  "include": ["src"]
}
